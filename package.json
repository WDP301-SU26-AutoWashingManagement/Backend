{
  "name": "autowash-backend",
  "version": "1.0.0",
  "description": "Auto Washing System Backend - TypeScript + Express + MongoDB",
  "main": "dist/app.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && tsc-alias",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/app.ts",
    "lint": "eslint src --ext .ts",
    "seed": "ts-node -r tsconfig-paths/register scripts/seed.ts",
    "test": "jest --runInBand --forceExit",
    "test:perf": "ts-node -r tsconfig-paths/register src/__tests__/replicator.perf.runner.ts",
    "test:perf:jest": "jest --config jest.config.perf.js --runInBand --forceExit",
    "test:perf:watch": "jest --config jest.config.perf.js --runInBand --watch",
    "test:perf:verbose": "jest --config jest.config.perf.js --runInBand --forceExit --verbose",
    "test:perf:coverage": "jest --config jest.config.perf.js --runInBand --forceExit --coverage"
  },
  "dependencies": {
    "@payos/node": "^2.0.5",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cronstrue": "^3.24.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "mongoose-delete": "^1.0.7",
    "mongoose-paginate-v2": "^1.8.0",
    "morgan": "^1.10.0",
    "mqtt": "^5.15.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.19.1",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mongoose-delete": "^1.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
